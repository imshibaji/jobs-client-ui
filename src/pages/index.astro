---
import '../styles/index.css';
import Navbar from './_parts/front/Navbar.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Jobs For Woman</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
</head>
<body>

<Navbar />

<!-- HERO -->
<div class="hero">
  <div class="hero-badge">✨ 🚀 Launching Soon - Register Now!</div>
  <h1>Empowering Women's Career Journey</h1>
  <p>Where talented women professionals connect with progressive companies that champion diversity, equality, and meaningful career growth.</p>
  <div class="hero-btns">
    <a href="https://n8n.jobsforwoman.com/form/registration" class="btn-hero-outline">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Register as Candidate
    </a>
    <a href="/register-as-employer" class="btn-hero-filled">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
      Register Your Company
    </a>
  </div>
</div>

<!-- STATS BAR -->
<div class="stats-bar">
  <div class="stat-item reveal">
    <div class="stat-value">Coming Soon</div>
    <div class="stat-label">Registered Candidates</div>
  </div>
  <div class="stat-item reveal reveal-delay-1">
    <div class="stat-value">Launching</div>
    <div class="stat-label">Partner Companies</div>
  </div>
  <div class="stat-item reveal reveal-delay-2">
    <div class="stat-value">2026</div>
    <div class="stat-label">Platform Launch</div>
  </div>
</div>

<!-- VISION -->
<section class="vision-section">
  <div class="section-inner">
    <div class="vision-grid">
      <div class="vision-images reveal">
        <div class="vision-img">
          <img src="https://images.unsplash.com/photo-1567532939604-b6b5b0db2604?w=400&q=80" alt="Vision - historical woman leader" />
        </div>
        <div class="vision-img">
          <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=400&q=80" alt="Vision - modern woman professional" />
        </div>
      </div>
      <div class="vision-text reveal reveal-delay-2">
        <h2>The Vision</h2>
        <blockquote>"We are building a legacy where we make sure that every woman in India either has a seat at the table or we create a seat she deserves. We believe professional excellence has no gender, only merit."</blockquote>
        <div class="founders-label">Yakshita &amp; Mahak — Founding Partners</div>
      </div>
    </div>
  </div>
</section>

<!-- WHY CHOOSE -->
<section class="why-section">
  <div class="section-inner">
    <div class="section-header reveal">
      <h2>Why Choose JobsForWoman?</h2>
      <p>A platform built specifically to address the unique needs and challenges faced by women in the workplace</p>
    </div>
    <div class="features-grid">
      <div class="feature-card reveal">
        <div class="feature-icon">👩‍💼</div>
        <h3>Exclusive for Women</h3>
        <p>A dedicated platform connecting talented women with inclusive employers</p>
      </div>
      <div class="feature-card reveal reveal-delay-1">
        <div class="feature-icon">🛡️</div>
        <h3>Safe &amp; Inclusive</h3>
        <p>Verified companies committed to gender equality and women's empowerment</p>
      </div>
      <div class="feature-card reveal reveal-delay-2">
        <div class="feature-icon">📈</div>
        <h3>Career Growth</h3>
        <p>Access opportunities that prioritize professional development and advancement</p>
      </div>
      <div class="feature-card reveal reveal-delay-3">
        <div class="feature-icon">🏆</div>
        <h3>Quality Opportunities</h3>
        <p>Curated positions from companies with proven diversity records</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS + TOOLS -->
<section class="how-section">
  <div class="section-inner">
    <div class="section-header reveal">
      <h2>How It Works</h2>
      <p>Getting started is simple and takes just a few minutes</p>
    </div>
    <div class="steps-grid">
      <div class="step-item reveal">
        <div class="step-num">1</div>
        <h3>Register Your Profile</h3>
        <p>Create your account as a candidate or company in minutes</p>
      </div>
      <div class="step-item reveal reveal-delay-1">
        <div class="step-num">2</div>
        <h3>Get Verified</h3>
        <p>We verify all profiles to ensure authenticity and safety</p>
      </div>
      <div class="step-item reveal reveal-delay-2">
        <div class="step-num">3</div>
        <h3>Connect &amp; Grow</h3>
        <p>Start matching with opportunities or finding top talent</p>
      </div>
    </div>
  </div>
</section>

<!-- CAREER TOOLS -->
<section class="tools-section">
  <div class="section-inner">
    <div class="text-center reveal">
      <div class="tools-badge">💡 Powerful Career Tools</div>
      <h2 style="font-family:'Playfair Display',serif;font-size:2.2rem;margin-bottom:12px;">Everything You Need to Succeed</h2>
      <p style="color:var(--text-muted);max-width:520px;margin:0 auto;">Access cutting-edge tools designed to accelerate your career growth</p>
    </div>
    <div class="tools-grid">
      <div class="tool-card reveal">
        <div class="coming-soon-badge">Coming Soon</div>
        <div class="tool-icon">📄</div>
        <h3>AI Resume Builder</h3>
        <p>Create ATS-friendly resumes tailored to your dream job</p>
      </div>
      <div class="tool-card reveal reveal-delay-1">
        <div class="coming-soon-badge">Coming Soon</div>
        <div class="tool-icon">₹</div>
        <h3>Salary Negotiator</h3>
        <p>Get data-driven insights in ₹ to negotiate your worth confidently</p>
      </div>
      <div class="tool-card reveal reveal-delay-2">
        <div class="coming-soon-badge">Coming Soon</div>
        <div class="tool-icon">🎥</div>
        <h3>Mock Interviews</h3>
        <p>Practice with AI-powered interview simulations</p>
      </div>
      <div class="tool-card reveal reveal-delay-3">
        <div class="coming-soon-badge">Coming Soon</div>
        <div class="tool-icon">📚</div>
        <h3>Skill Courses</h3>
        <p>Free access to career development and upskilling programs</p>
      </div>
    </div>
  </div>
</section>

<!-- COMMUNITY -->
<section class="community-section">
  <div class="section-inner">
    <div class="community-box reveal">
      <div class="section-header" style="margin-bottom:0;">
        <h2>Join Our Thriving Community</h2>
        <p>Connect, learn, and grow with thousands of ambitious women professionals</p>
      </div>
      <div class="community-grid">
        <div class="community-card">
          <div class="comm-icon">🤝</div>
          <div>
            <h3>Mentorship Matching</h3>
            <p>Connect with senior women leaders for career guidance and support</p>
          </div>
        </div>
        <div class="community-card">
          <div class="comm-icon">📅</div>
          <div>
            <h3>Virtual Events</h3>
            <p>Join webinars, workshops, and networking sessions exclusively for women</p>
          </div>
        </div>
        <div class="community-card">
          <div class="comm-icon">💬</div>
          <div>
            <h3>Community Forum</h3>
            <p>Share experiences, ask questions, and support fellow professionals</p>
          </div>
        </div>
        <div class="community-card">
          <div class="comm-icon">🎯</div>
          <div>
            <h3>Career Path Visualizer</h3>
            <p>Explore potential career trajectories based on your goals and skills</p>
          </div>
        </div>
      </div>
      <div class="text-center">
        <button class="explore-btn">Explore All Features →</button>
      </div>
    </div>
  </div>
</section>

<!-- STARTUP INDIA -->
<section class="startup-section">
  <div class="section-inner">
    <div class="startup-box reveal">
      <div class="startup-img-wrap">
        <img src="https://images.unsplash.com/photo-1589994965851-a8f479c573a9?w=600&q=80" alt="Startup India Certificate" />
      </div>
      <div class="startup-text">
        <h2>Startup India Certificate</h2>
        <p>This is to certify that <strong>SHEPRENEUR ERA PRIVATE LIMITED</strong> incorporated as a Private Limited Company on <strong>01-10-2025</strong>, is recognized as Startup by the Department for Promotion of Industry and Internal Trade. The Startup is working in 'Professional &amp; Commercial Services' industry and 'Others' sector as self-certified by them.</p>
        <p>This certificate shall only be valid for the Entity up to Ten years from the date of its Incorporation only if its turnover for any of the financial years has not exceeded ₹100 Cr.</p>
        <a href="#" class="learn-more-btn">Learn More ↗</a>
      </div>
    </div>
  </div>
</section>

<!-- FOR CANDIDATES -->
<section style="background:var(--bg-mid);padding:40px 60px;">
  <div class="section-inner">
    <div class="cta-box reveal">
      <div class="cta-text">
        <h2>For Women Seeking Opportunities</h2>
        <p>Register now to be among the first candidates when we launch. Build your profile and get matched with companies that value diversity.</p>
        <ul class="cta-list">
          <li><div class="check-icon">✓</div> Access exclusive job opportunities from verified companies</li>
          <li><div class="check-icon">✓</div> Build a professional profile highlighting your skills</li>
          <li><div class="check-icon">✓</div> Connect with employers committed to gender equality</li>
        </ul>
        <a href="https://n8n.jobsforwoman.com/form/registration" class="cta-btn">Register as Candidate →</a>
      </div>
      <div class="cta-img">
        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80" alt="Woman professional reviewing documents" />
      </div>
    </div>

    <!-- FOR COMPANIES -->
    <div class="cta-box reveal" style="grid-template-columns:1fr 1fr;">
      <div class="cta-img cta-img-left">
        <img src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=600&q=80" alt="Company team" />
      </div>
      <div class="cta-text">
        <h2>For Companies Committed to Diversity</h2>
        <p>Register your company to access a pool of talented women professionals ready to contribute to your organization's success.</p>
        <ul class="cta-list">
          <li><div class="check-icon">✓</div> Showcase your commitment to gender diversity</li>
          <li><div class="check-icon">✓</div> Post unlimited job opportunities when we launch</li>
          <li><div class="check-icon">✓</div> Connect with qualified candidates who align with your values</li>
        </ul>
        <a href="/register-as-employer" class="cta-btn">Register Your Company →</a>
      </div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<div class="final-cta reveal reveal-delay-1">
  <h2>Be Part of the Change</h2>
  <p>Join us in creating a more inclusive workplace. Register today and be among the first when we launch.</p>
  <div class="final-btns">
    <a href="https://n8n.jobsforwoman.com/form/registration" class="final-btn-outline">I'm Looking for Jobs</a>
    <a href="/register-as-employer" class="final-btn-filled">I'm Hiring Talent</a>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <p>© 2026 Shepreneur Era Private Limited · Made for women, by women 💜</p>
</footer>
</body>
</html>

<script is:inline>
  // Hamburger menu
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
  });

  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });
  reveals.forEach(el => observer.observe(el));
</script>