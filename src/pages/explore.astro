---
import '../styles/explore.css';
import Navbar from './_parts/front/Navbar.astro';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<link rel="icon" href="/favicons/favicon.ico" />
<title>Explore – Jobs for Women Portal</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
</head>
<body>

<!-- STAR FIELD -->
<div class="stars" id="stars"></div>

<Navbar />

<!-- HERO -->
<div class="hero">
  <h1>About Us</h1>
  <p>Learn who we are, what we stand for, and why we're building the most trusted job platform for women in India</p>
</div>

<!-- STATS ROW -->
<div class="stats-row">
  <div class="stat-col reveal">
    <div class="stat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
    <div class="stat-val">Coming Soon</div>
    <div class="stat-lbl">Platform Launch</div>
  </div>
  <div class="stat-col reveal reveal-delay-1">
    <div class="stat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
    <div class="stat-val">Growing Daily</div>
    <div class="stat-lbl">Early Registrations</div>
  </div>
  <div class="stat-col reveal reveal-delay-2">
    <div class="stat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg></div>
    <div class="stat-val">Signing Up</div>
    <div class="stat-lbl">Partner Companies</div>
  </div>
  <div class="stat-col reveal reveal-delay-3">
    <div class="stat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg></div>
    <div class="stat-val">Starting Soon</div>
    <div class="stat-lbl">Success Stories</div>
  </div>
</div>

<!-- MISSION & VISION -->
<section class="section" style="background: var(--bg-deep);">
  <div class="section-inner">
    <div class="mv-grid">
      <div class="mv-card reveal">
        <div class="mv-header">
          <div class="mv-icon">
            <svg width="22" height="22" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <h3>Our Mission</h3>
        </div>
        <p>To empower every woman with job opportunities that match her needs and lifestyle, along with access to skill-building tools and a safe, trustworthy platform. We are committed to helping women—no matter where they come from—restart or grow their careers with confidence, respect, and purpose.</p>
      </div>
      <div class="mv-card reveal reveal-delay-2">
        <div class="mv-header">
          <div class="mv-icon">
            <svg width="22" height="22" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3>Our Vision</h3>
        </div>
        <p>To be recognized as the most trusted global platform dedicated to creating abundant opportunities for women, empowering them with equality, dignity, and sustainable careers.</p>
      </div>
    </div>
  </div>
</section>

<!-- PLATFORM FEATURES -->
<section class="section" style="background: var(--bg-mid);">
  <div class="section-inner">
    <div class="section-header reveal">
      <h2>Platform Features</h2>
      <p>Everything you need to find the perfect match between talent and opportunity</p>
    </div>
    <div class="features-3">
      <div class="feat-card reveal">
        <div class="feat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></div>
        <h3>Verified Companies</h3>
        <p>Every company is manually verified to ensure commitment to gender equality and inclusive workplace policies.</p>
      </div>
      <div class="feat-card reveal reveal-delay-1">
        <div class="feat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div>
        <h3>Tailored Matching</h3>
        <p>Advanced algorithms match candidates with opportunities based on skills, preferences, and career goals.</p>
      </div>
      <div class="feat-card reveal reveal-delay-2">
        <div class="feat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
        <h3>Safe Environment</h3>
        <p>A supportive community where women can explore opportunities without bias or discrimination.</p>
      </div>
      <div class="feat-card reveal reveal-delay-1">
        <div class="feat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
        <h3>Career Growth</h3>
        <p>Access mentorship programs, skill development resources, and networking opportunities.</p>
      </div>
      <div class="feat-card reveal reveal-delay-2">
        <div class="feat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg></div>
        <h3>Remote Opportunities</h3>
        <p>Discover flexible and remote positions that support work-life balance and family needs.</p>
      </div>
      <div class="feat-card reveal reveal-delay-3">
        <div class="feat-icon"><svg width="20" height="20" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg></div>
        <h3>Quality First</h3>
        <p>Curated positions from companies with proven track records in women's empowerment.</p>
      </div>
    </div>
  </div>
</section>

<!-- INDUSTRIES -->
<section class="section industries-section">
  <div class="section-inner">
    <div class="section-header reveal">
      <h2>Industries We Serve</h2>
      <p>Opportunities across diverse sectors and fields</p>
    </div>
    <div class="industry-grid">
      <div class="industry-tag reveal">Technology</div>
      <div class="industry-tag reveal reveal-delay-1">Healthcare</div>
      <div class="industry-tag reveal reveal-delay-2">Finance</div>
      <div class="industry-tag reveal reveal-delay-3">Education</div>
      <div class="industry-tag reveal reveal-delay-1">Marketing</div>
      <div class="industry-tag reveal reveal-delay-2">Design</div>
      <div class="industry-tag reveal reveal-delay-3">Consulting</div>
      <div class="industry-tag reveal reveal-delay-4">Non-Profit</div>
    </div>
  </div>
</section>

<!-- FOR CANDIDATES & COMPANIES -->
<section class="section" style="background:var(--bg-deep);">
  <div class="section-inner">
    <div class="register-grid">
      <div class="reg-card reveal">
        <div class="reg-header">
          <div class="reg-icon">👩‍💼</div>
          <h3>For Candidates</h3>
        </div>
        <ul class="reg-list">
          <li><div class="check">✓</div> Access to exclusive job opportunities</li>
          <li><div class="check">✓</div> Profile visibility to top employers</li>
          <li><div class="check">✓</div> Career guidance and resources</li>
          <li><div class="check">✓</div> Networking with like-minded professionals</li>
          <li><div class="check">✓</div> Transparent salary information</li>
          <li><div class="check">✓</div> Company culture insights</li>
        </ul>
        <button class="reg-btn">Register as Candidate</button>
      </div>
      <div class="reg-card reveal reveal-delay-2">
        <div class="reg-header">
          <div class="reg-icon">🏢</div>
          <h3>For Companies</h3>
        </div>
        <ul class="reg-list">
          <li><div class="check">✓</div> Access to talented women professionals</li>
          <li><div class="check">✓</div> Boost your diversity hiring goals</li>
          <li><div class="check">✓</div> Showcase your inclusive culture</li>
          <li><div class="check">✓</div> Simplified hiring process</li>
          <li><div class="check">✓</div> Enhanced employer branding</li>
          <li><div class="check">✓</div> Early access to top talent</li>
        </ul>
        <button class="reg-btn">Register Your Company</button>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section" style="background:var(--bg-mid);">
  <div class="section-inner">
    <div class="how-box reveal">
      <div class="section-header" style="margin-bottom:0;">
        <h2>How It Works</h2>
        <p>Simple steps to get started</p>
      </div>
      <div class="steps-3">
        <div class="step">
          <div class="step-num">1</div>
          <h3>Create Your Profile</h3>
          <p>Sign up as a candidate or company and complete your profile with relevant information</p>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <h3>Get Verified</h3>
          <p>Our team reviews all profiles to ensure authenticity and alignment with our values</p>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <h3>Start Connecting</h3>
          <p>Once we launch, begin matching with opportunities or finding top talent</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<div class="final-cta reveal">
  <h2>Ready to Get Started?</h2>
  <p>Be among the first to join when we launch. Register today and help us build a more inclusive future.</p>
  <div class="final-btns">
    <button class="final-btn-outline">I'm a Candidate</button>
    <button class="final-btn-filled">I'm a Company</button>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <p>© 2026 Shepreneur Era Private Limited · Made for women, by women <svg style="display:inline;vertical-align:middle" width="14" height="14" fill="#c084fc" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></p>
</footer>

<script is:inline>
  // Generate star field
  const starsEl = document.getElementById('stars');
  for (let i = 0; i < 80; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random() * 2.5 + 1;
    s.style.cssText = `
      width:${size}px; height:${size}px;
      left:${Math.random()*100}%; top:${Math.random()*100}%;
      --dur:${(Math.random()*4+2).toFixed(1)}s;
      --delay:-${(Math.random()*5).toFixed(1)}s;
    `;
    starsEl.appendChild(s);
  }

  // Hamburger
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
  });

  // Scroll reveal
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));
</script>
</body>
</html>
