---
const pathname = Astro.url.pathname;
console.log(pathname);

---
<!-- NAVBAR -->
<nav>
<div class="nav-container">
  <a href="#" class="nav-logo">
    <img src="/logo.png" alt="JobsForWomen" class="inline-block h-8 w-8" />
    <div class="flex items-center text-2xl font-black">
        JobsForWoman
        <span class="text-xs text-gray-400 ml-1">Beta</span>
    </div>
  </a>
  <div class="nav-left">
    <a href="/" class={pathname === '/' ? 'nav-link active' : 'nav-link'}>
      <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
      Home
    </a>
    <a href="/explore" class={pathname === '/explore' ? 'nav-link active' : 'nav-link'}>
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      Explore
    </a>
    <a href="/quiz" class={pathname === '/quiz' ? 'nav-link active' : 'nav-link'}>
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="15" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
      Quiz
    </a>
  </div>
  <div class="nav-right">
    <a href="https://n8n.jobsforwoman.com/form/registration" class="btn-outline">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Candidate
    </a>
    <a href="/register-as-employer" class="btn-filled">
      <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
      Company
    </a>
  </div>
  <button class="hamburger" id="hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</div>
</nav>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
  <a href="/" class="nav-link">🏠 Home</a>
  <a href="/explore" class="nav-link">🔍 Explore</a>
  <a href="/quiz" class="nav-link">🎮 Quiz</a>
  <div class="mobile-menu-btns">
    <a href="https://n8n.jobsforwoman.com/form/registration" class="btn-outline">👤 Candidate</a>
    <a href="/register-as-employer" class="btn-filled">🏢 Company</a>
  </div>
</div>